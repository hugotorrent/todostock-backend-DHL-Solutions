doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title Productos - TodoStock S.A.
    style.
      body { 
        font-family: Arial, sans-serif; 
        background-color: #f4f4f9; 
        margin: 0; 
        padding: 40px 20px; 
      }
      .contenedor { 
        background: white; 
        padding: 30px; 
        border-radius: 10px; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.1); 
        max-width: 800px; 
        margin: 0 auto; 
      }
      h1 { color: #333; text-align: center; margin-bottom: 20px; }
      table { width: 100%; border-collapse: collapse; margin-top: 10px; }
      th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid #ddd; }
      th { background-color: #2c3e50; color: white; }
      .btn-volver { display: inline-block; margin-bottom: 20px; text-decoration: none; color: #2c3e50; font-weight: bold; }
      .btn-volver:hover { text-decoration: underline; }
      .stock-bajo { color: #dc3545; font-weight: bold; }
      .stock-ok { color: #28a745; font-weight: bold; }

  body
    div.contenedor
      a.btn-volver(href="/") ← Volver al Panel Principal
      h1 Inventario de Productos
      
      table
        thead
          tr
            th ID
            th Nombre
            th Precio
            th Stock Actual
            th Proveedor
        tbody
          each producto in productos
            tr
              td= producto.id
              td= producto.nombre
              td= "$" + producto.precio
              
              //- Lógica de stock con colores
              if producto.stock <= producto.stockMinimo
                td.stock-bajo #{producto.stock} (¡Reponer!)
              else
                td.stock-ok #{producto.stock}
                
              td= producto.proveedorNombre